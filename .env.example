PORT=5000
# MongoDB
# Use Atlas on VPS/production. Example:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/project_management
# Set true on VPS/production so the API never runs with temporary in-memory data.
REQUIRE_DATABASE=true
# Optional local-only maintenance flags. Keep false/blank in production.
ENABLE_DB_AUTO_CLEANUP=false
ENABLE_DB_DEBUG_DUMP=false

# Nodemailer SMTP Configuration
# Set these variables to send real emails via Gmail, Outlook, Mailtrap, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=


ATTENDANCE_TIMEZONE=Asia/Kolkata
# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Razorpay demo/test configuration
# Leave blank to use the app's built-in mock checkout flow.
RAZORPAY_KEY_ID=rzp_test_demo_key_id
RAZORPAY_KEY_SECRET=rzp_test_demo_key_secret
